DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST= 
DATABASE_PORT=
DATABASE_NAME=

# jwt secret keys
JWT_SECRET_KEY=

# Access token lifetime (default 15m). Refresh tokens default to 7d.
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# On server start, this user's role is set to platform_admin (comma-separated not supported)
PLATFORM_ADMIN_EMAIL=

BACKEND_PORT=

# Optional: absolute path or path relative to the backend folder. Default: src/storage/uploads
# Use this if uploads live outside the repo or you start Node with a cwd that is not backend/.
UPLOADS_PHYSICAL_ROOT=

# running in local — also used as SPA origin for Stripe Checkout/Portal redirects
BASE_URL=

# Comma-separated extra CORS origins allowed in production (BASE_URL is always included)
# CORS_ALLOWED_ORIGINS=

# Preferred portal origin for emails (falls back to BASE_URL)
# FRONTEND_URL=

# Optional: full URL to the sign-in page (overrides FRONTEND_URL + /signin).
# SIGNIN_PAGE_URL=https://your-portal.example.com/signin

# Log each deal member's commitment fields to the server console when GET /deals/:id/members runs.
# DEAL_MEMBERS_COMMIT_DEBUG=

#email configuration
EMAIL_SERVICE_TYPE=
SENDER_EMAIL_ID=
SENDER_EMAIL_PASSWORD=

# SignFlow eSign — primary integration (see API_INTEGRATION.md in repo root)
# Local dev example: http://localhost:5007/api/v1
SIGNFLOW_API_BASE_URL=
SIGNFLOW_API_KEY=
# HMAC secret for SignFlow webhooks (defaults to SIGNFLOW_API_KEY when unset)
# SIGNFLOW_WEBHOOK_SECRET=
# Dev only: set SIGNFLOW_WEBHOOK_REQUIRE_VERIFY=1 to enforce signature checks locally
# SIGNFLOW_WEBHOOK_SKIP_VERIFY=1
# Optional: SignFlow web UI for embedded editor/signing iframes
# SIGNFLOW_APP_BASE_URL=http://localhost:5177
# Optional: public embed key for production embedded UI
# SIGNFLOW_EMBED_API_KEY=

# Optional: Python onboarding fields service
# ONBOARDING_FIELDS_SERVICE_URL=http://localhost:5008

# GoHighLevel (GHL) — contact sync to your sub-account
# PRIVATE_INTEGRATION_KEY=pit-...
# GHL_LOCATION_ID=your-sub-account-id
# GHL_APP_BASE_URL=https://app.gohighlevel.com
# GHL_SYNC_ENABLED=1
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28
#
# Per-org sub-accounts (Agency Pro — POST /locations/):
# GHL_PER_ORG_LOCATIONS=1
# GHL_AGENCY_PRIVATE_INTEGRATION_KEY=pit-...
# GHL_COMPANY_ID=your-agency-company-id
# GHL_SNAPSHOT_ID=optional-snapshot-id

# API key: https://app.hellosign.com/home/myAccount#api
# Client ID: https://app.hellosign.com/oauth/createAppForm (domain must match your portal host)
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=
# Use true until your embedded app is approved for production
DROPBOX_SIGN_TEST_MODE=true

# ---------------------------------------------------------------------------
# Stripe — per-company SaaS billing (same code for local + production)
# ---------------------------------------------------------------------------
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Local:  stripe listen --forward-to localhost:<BACKEND_PORT>/api/webhooks/stripe
# Prod:   Dashboard webhook → https://<api-host>/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Starter (only plan enabled for self-serve checkout today)
STARTER_MONTH_PRICING=price_...
STARTER_YEARLY_PRICING=price_...
# Optional later (UI currently disabled)
# RUNNING_MONTH_PRICING=price_...
# RUNNING_YEARLY_PRICING=price_...
# GROWTH_MONTH_PRICING=price_...
# GROWTH_YEARLY_PRICING=price_...
# Dev only — never set in production
# STRIPE_WEBHOOK_SKIP_VERIFY=1
